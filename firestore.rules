rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 유저 정보 및 하위 데이터 통합 관리
    match /users/{userId} {
      // 1. 유저 문서 자체에 대한 권한
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // 2. 학생/외부 접근이 필요한 컬렉션 (쓰기 허용 유지)
      match /students/{id} { allow read, write: if true; }
      match /accumulated_records/{id} { allow read, write: if true; }
      match /student_questions/{id} { allow read, write: if true; }
      match /growth_detail_records/{id} { allow read, write: if true; }
      match /attendance/{id} { allow read, write: if true; }
      
      // 3. 그 외 모든 하위 컬렉션 (선생님 전용 데이터)
      // classes, clubs, settings, offsets, curriculum, progress_check 등 모든 경로 포함
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
