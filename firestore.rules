rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. 유저 정보 (교실 검색을 위해 공개 읽기 허용)
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // 하위 컬렉션들: 학생이 접근해야 하는 경로들
      
      match /students/{studentId} {
        allow read: if true;
        allow write: if true; 
      }
      
      match /classes/{classId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /clubs/{clubId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /accumulated_records/{recordId} {
        allow read, write: if true; 
      }

      match /student_questions/{questionId} {
        allow read, write: if true; 
      }

      match /growth_detail_records/{recordId} {
        allow read, write: if true; 
      }
      
      match /growth_categories/{catId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
